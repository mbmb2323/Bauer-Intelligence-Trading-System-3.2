# ─────────────────────────────────────────────────────────────────────────────
# BITS 3.2  –  Environment Variable Overrides
# Copy this file to .env and fill in your secrets.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Database (overrides config.yaml data.database_url)
# DATABASE_URL=******localhost:5432/bits

# Alpaca brokerage
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret

# Interactive Brokers
# IB_HOST=127.0.0.1
# IB_PORT=7497
# IB_CLIENT_ID=1

# MLflow remote tracking (optional – defaults to local mlruns/)
# MLFLOW_TRACKING_URI=http://localhost:5000

# Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_FROM=alerts@example.com
# EMAIL_TO=trader@example.com

# Logging
# LOG_LEVEL=DEBUG
